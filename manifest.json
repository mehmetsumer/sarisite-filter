{
    "name": "Sarı Site Çoklu Filtreleme",
    "description": "Sarı Site (Sahibinden Çoklu Filtreleme) platformunda birden fazla markayı, modeli çoklu seçim yaparak filtreleyebilirsiniz.",
    "version": "1.6",
    "manifest_version": 3,
    "permissions": [ "storage" ],
    "action": {
      "default_popup": "index.html",
      "default_icon": "icon.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [ "https://www.sahibinden.com/*", "https://sahibinden.com/*" ],
            "js": [ "jquery-3.7.1.min.js", "content-script.js" ]
        }
    ]
  }